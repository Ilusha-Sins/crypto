generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  MARKET
}

enum OrderStatus {
  FILLED
  REJECTED
}

enum PositionStatus {
  OPEN
  CLOSED
}

model User {
  id              String            @id @default(cuid())
  email           String            @unique
  passwordHash    String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  demoAccount     DemoAccount?
  analysisHistory AnalysisHistory[]
}

model DemoAccount {
  id             String     @id @default(cuid())
  userId         String     @unique
  initialBalance Decimal    @db.Decimal(18, 8)
  cashBalance    Decimal    @db.Decimal(18, 8)
  resetCount     Int        @default(0)
  lastResetAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  positions      Position[]
  orders         Order[]
  trades         Trade[]
}

model Position {
  id                String         @id @default(cuid())
  accountId         String
  symbol            String
  quantity          Decimal        @db.Decimal(18, 8)
  averageEntryPrice Decimal        @db.Decimal(18, 8)
  stopLoss          Decimal?       @db.Decimal(18, 8)
  takeProfit        Decimal?       @db.Decimal(18, 8)
  status            PositionStatus @default(OPEN)
  openedAt          DateTime       @default(now())
  closedAt          DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  account           DemoAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  trades            Trade[]

  @@index([accountId, symbol, status])
}

model Order {
  id             String      @id @default(cuid())
  accountId      String
  symbol         String
  side           OrderSide
  type           OrderType   @default(MARKET)
  quantity       Decimal     @db.Decimal(18, 8)
  executionPrice Decimal?    @db.Decimal(18, 8)
  status         OrderStatus
  rejectionReason String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  account        DemoAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  trade          Trade?

  @@index([accountId, createdAt])
}

model Trade {
  id          String      @id @default(cuid())
  accountId   String
  orderId     String      @unique
  positionId  String?
  symbol      String
  side        OrderSide
  quantity    Decimal     @db.Decimal(18, 8)
  price       Decimal     @db.Decimal(18, 8)
  executedAt  DateTime    @default(now())
  realizedPnl Decimal?    @db.Decimal(18, 8)
  account     DemoAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  position    Position?   @relation(fields: [positionId], references: [id], onDelete: SetNull)

  @@index([accountId, executedAt])
}

model AnalysisHistory {
  id        String   @id @default(cuid())
  userId    String
  symbol    String
  interval  String
  response  Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}